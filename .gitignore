# =============================================
# Python
# =============================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python

# =============================================
# Virtual Environment / Poetry
# =============================================
.venv/
venv/
env/
.env
.env.*

# =============================================
# 데이터 파일 (원시 데이터 & 전처리 결과)
# 용량이 크거나 개인정보가 포함될 수 있어 Git에 올리지 않음
# =============================================
data/raw/
data/processed/
!data/raw/.gitkeep
!data/processed/.gitkeep

# =============================================
# 학습된 모델 파일 (용량이 크므로 Git 제외)
# =============================================
models/saved/
!models/saved/.gitkeep
*.pkl
*.pt
*.pth
*.h5

# =============================================
# 나만 보는 가이드북 (포트폴리오 제출용이 아님)
# =============================================
docs/GUIDEBOOK.md

# =============================================
# API 키 & 시크릿 (절대 GitHub에 올리면 안됨!)
# =============================================
.env
*.env
secrets.toml
.streamlit/secrets.toml

# =============================================
# Jupyter Notebook 체크포인트
# =============================================
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# =============================================
# IDE
# =============================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# =============================================
# 테스트 / 커버리지
# =============================================
.pytest_cache/
.coverage
htmlcov/

# =============================================
# FAISS 인덱스 (크기에 따라 제외)
# =============================================
*.faiss
*.index
